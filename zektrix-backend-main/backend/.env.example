# Example backend environment variables
# Copy this to .env and fill in your values

# MongoDB Connection
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=zektrix_db

# CORS
CORS_ORIGINS=*

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Viva Payments (Production)
VIVA_CLIENT_ID=your_viva_client_id.apps.vivapayments.com
VIVA_CLIENT_SECRET=your_viva_client_secret
VIVA_API_URL=https://api.vivapayments.com
VIVA_CHECKOUT_URL=https://www.vivapayments.com/web/checkout

# Resend Email
RESEND_API_KEY=re_your_resend_api_key

# AI Integration (Emergent LLM Key for GPT-5.2)
EMERGENT_LLM_KEY=sk-emergent-your_key_here
